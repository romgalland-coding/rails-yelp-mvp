<div class="container">
  <%= link_to restaurants_path, class: "text-decoration-none text-muted small mb-3 d-inline-block" do %>
    <i class="fa-solid fa-arrow-left me-1"></i> Back to restaurants
  <% end %>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4 p-md-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
          <span class="badge bg-warning text-dark text-capitalize mb-2"><%= @restaurant.category %></span>
          <h1 class="fw-bold mb-2"><%= @restaurant.name %></h1>
          <p class="text-muted mb-0">
            <i class="fa-solid fa-location-dot me-2"></i><%= @restaurant.address %>
          </p>
        </div>
        <div class="text-center bg-light rounded-3 p-3" style="min-width: 120px;">
          <div class="display-6 fw-bold text-warning mb-0">
            <%= @restaurant.average_rating %>
          </div>
          <div class="text-warning small mb-1">
            <% 5.times do |i| %>
              <% if i < @restaurant.average_rating.to_f.round %>
                <i class="fa-solid fa-star"></i>
              <% else %>
                <i class="fa-regular fa-star"></i>
              <% end %>
            <% end %>
          </div>
          <small class="text-muted"><%= @restaurant.reviews.count %> reviews</small>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <h3 class="fw-bold mb-3">Reviews</h3>

      <% if @restaurant.reviews.any? %>
        <div class="d-flex flex-column gap-3">
          <% @restaurant.reviews.each do |review| %>
            <div class="card border-0 shadow-sm rounded-4">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div class="text-warning">
                    <% 5.times do |i| %>
                      <% if i < review.rating.to_i %>
                        <i class="fa-solid fa-star"></i>
                      <% else %>
                        <i class="fa-regular fa-star"></i>
                      <% end %>
                    <% end %>
                  </div>
                  <span class="badge bg-light text-dark"><%= review.rating %>/5</span>
                </div>
                <p class="mb-0"><%= review.content %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="card border-0 bg-light rounded-4">
          <div class="card-body text-center py-5">
            <i class="fa-regular fa-comment fa-2x text-muted mb-3"></i>
            <p class="text-muted mb-0">No reviews yet. Be the first to share your experience!</p>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 90px;">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-25 rounded-circle mb-2" style="width: 50px; height: 50px;">
              <i class="fa-solid fa-pen text-warning"></i>
            </div>
            <h4 class="fw-bold mb-1">Leave a review</h4>
            <p class="text-muted small mb-0">Share your experience</p>
          </div>

          <%= simple_form_for([@restaurant, @review]) do |f| %>
            <%= f.error_notification %>
            <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

            <div class="mb-3">
              <%= f.input :content, as: :text, input_html: { class: "form-control", rows: 4, placeholder: "Tell us about your experience..." } %>
            </div>
            <div class="mb-3">
              <%= f.input :rating, collection: (0..5), input_html: { class: "form-select" } %>
            </div>

            <div class="d-grid">
              <%= f.button :submit, "Submit review", class: "btn btn-warning fw-semibold" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
