<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-1">Restaurants</h1>
      <p class="text-muted mb-0">Discover restaurants loved by our community</p>
    </div>
    <span class="badge bg-secondary fs-6"><%= @restaurants.count %> restaurants</span>
  </div>

  <div class="row g-4">
    <% @restaurants.each do |restaurant| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden restaurant-card">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <span class="badge bg-warning text-dark text-capitalize"><%= restaurant.category %></span>
              <span class="text-muted small">
                <i class="fa-solid fa-star text-warning"></i>
                <%= restaurant.average_rating %>
              </span>
            </div>
            <h5 class="card-title fw-bold mb-2"><%= restaurant.name %></h5>
            <p class="card-text text-muted small mb-3">
              <i class="fa-solid fa-location-dot me-1"></i><%= restaurant.address %>
            </p>
            <%= link_to restaurant_path(restaurant), class: "btn btn-outline-dark btn-sm w-100" do %>
              View details <i class="fa-solid fa-arrow-right ms-1"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @restaurants.empty? %>
    <div class="text-center py-5">
      <i class="fa-solid fa-utensils fa-3x text-muted mb-3"></i>
      <p class="text-muted">No restaurants yet. Be the first to add one!</p>
    </div>
  <% end %>
</div>
