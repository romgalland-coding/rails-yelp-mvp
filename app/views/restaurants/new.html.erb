<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <%= link_to restaurants_path, class: "text-decoration-none text-muted small mb-3 d-inline-block" do %>
        <i class="fa-solid fa-arrow-left me-1"></i> Back to restaurants
      <% end %>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-25 rounded-circle mb-3" style="width: 60px; height: 60px;">
              <i class="fa-solid fa-utensils fa-lg text-warning"></i>
            </div>
            <h2 class="fw-bold mb-1">Add a new restaurant</h2>
            <p class="text-muted small mb-0">Share a great place with the community</p>
          </div>

          <%= simple_form_for(@restaurant) do |f| %>
            <%= f.error_notification %>
            <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

            <div class="mb-3">
              <%= f.input :name, input_html: { class: "form-control form-control-lg" } %>
            </div>
            <div class="mb-3">
              <%= f.input :address, input_html: { class: "form-control form-control-lg" } %>
            </div>
            <div class="mb-4">
              <%= f.input :category, collection: Restaurant::CATEGORY, input_html: { class: "form-select form-select-lg" } %>
            </div>

            <div class="d-grid">
              <%= f.button :submit, "Create restaurant", class: "btn btn-warning btn-lg fw-semibold" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
