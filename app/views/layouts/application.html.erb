<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Yelp Mvp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rails Yelp Mvp">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
      <div class="container">
        <%= link_to restaurants_path, class: "navbar-brand fw-bold" do %>
          <i class="fa-solid fa-utensils me-2 text-warning"></i>Yelp MVP
        <% end %>

        <%= link_to new_restaurant_path, class: "btn btn-warning fw-semibold" do %>
          <i class="fa-solid fa-plus me-2"></i>Add a restaurant
        <% end %>
      </div>
    </nav>

    <main class="py-4">
      <%= yield %>
    </main>

    <footer class="bg-dark text-light text-center py-3 mt-5">
      <small>&copy; <%= Date.current.year %> Yelp MVP — Built with Rails</small>
    </footer>
  </body>
</html>
